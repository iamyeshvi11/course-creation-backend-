# Server Configuration
NODE_ENV=development
PORT=5000

# Database
MONGO_URI=mongodb://localhost:27017/womenwalnut
# Or use MongoDB Atlas:
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/womenwalnut?retryWrites=true&w=majority

# JWT Secret
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRE=30d

# Frontend URL
FRONTEND_URL=http://localhost:3000

# OpenAI Configuration (Optional - for AI content generation)
OPENAI_API_KEY=your_openai_api_key_here
USE_AI_GENERATION=false
OPENAI_MODEL=gpt-4

# Email Configuration (Required for notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@company.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM="Training Portal <training@company.com>"

# Enable automated reminders
ENABLE_REMINDERS=true

# File Upload Configuration (Optional)
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# AWS S3 Configuration (Optional - for file storage)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket-name
USE_S3_STORAGE=false
